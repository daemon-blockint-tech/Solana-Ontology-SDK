{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "src/generated/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "generate": {
      "dependsOn": ["build"],
      "outputs": ["src/generated/**"],
      "cache": false
    },
    "docs": {
      "dependsOn": ["build"],
      "outputs": ["docs/**"],
      "cache": false
    }
  }
}
