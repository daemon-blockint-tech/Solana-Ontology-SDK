  },
  "dependencies": {
    "yaml": "^2.4.0",
    "ajv": "^8.13.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^3.2.6",
    "@types/node": "^20.14.0"
  }
