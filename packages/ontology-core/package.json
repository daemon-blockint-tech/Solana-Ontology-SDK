{
  "name": "@solana-ontology/core",
  "version": "0.1.0",
  "description": "Core types, loader, and validator for the Solana Ontology SDK",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
