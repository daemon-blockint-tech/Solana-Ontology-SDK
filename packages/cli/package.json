{
  "name": "@solana-ontology/cli",
  "version": "0.1.0",
  "description": "CLI for validating and generating code from the Solana Ontology",
  "type": "module",
  "bin": {
    "solana-ontology": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@solana-ontology/core": "workspace:*",
    "@solana-ontology/generator-ts": "workspace:*",
    "@solana-ontology/generator-rust": "workspace:*",
    "@solana-ontology/idl-parser": "workspace:*",
    "@solana-ontology/oms": "workspace:*",
    "@solana-ontology/mcp-server": "workspace:*",
    "@solana-ontology/generator-client": "workspace:*",
    "commander": "^12.1.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.14.0"
  }
}
