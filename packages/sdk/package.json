{
  "name": "@solana-ontology/sdk",
  "version": "0.1.0",
  "description": "Runtime SDK for the Solana Ontology with @solana/kit and web3.js v1 adapter",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist .turbo src/generated"
  },
  "dependencies": {
    "@solana-ontology/core": "workspace:*",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^3.2.6",
    "@types/node": "^20.14.0"
  },
  "peerDependencies": {
    "@solana/kit": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@solana/kit": {
      "optional": true
    }
  }
}
